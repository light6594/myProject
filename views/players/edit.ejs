<main class="form-page">
  <form action="/edit/<%= data._id %>?_method=PUT" method="post" class="form-box wide">
    <h1>선수 수정</h1>
    <label>
      선수 이름
      <input type="text" name="name" value="<%= data.name %>" required>
    </label>
    <label>
      포지션
      <select name="position" required>
        <option value="GK" <%= data.position === "GK" ? "selected" : "" %>>GK</option>
        <option value="DF" <%= data.position === "DF" ? "selected" : "" %>>DF</option>
        <option value="MF" <%= data.position === "MF" ? "selected" : "" %>>MF</option>
        <option value="FW" <%= data.position === "FW" ? "selected" : "" %>>FW</option>
      </select>
    </label>
    <label>
      등번호
      <input type="number" name="number" min="1" max="99" value="<%= data.number %>" required>
    </label>
    <label>
      소속팀
      <input type="text" name="team" value="<%= data.team %>" required>
    </label>
    <label>
      메모
      <textarea name="memo" rows="5"><%= data.memo %></textarea>
    </label>
    <button type="submit">수정하기</button>
  </form>
</main>
