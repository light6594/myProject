<main class="form-page">
  <form action="/login" method="post" class="form-box">
    <h1>로그인</h1>
    <label>
      아이디
      <input type="text" name="username" required>
    </label>
    <label>
      비밀번호
      <input type="password" name="password" required>
    </label>
    <button type="submit">로그인</button>
  </form>
</main>
